@startuml
title Reschedule Lesson — Teacher (Detailed)

actor Teacher as T
participant "LMS (Scheduler)" as LMS
participant Student as S

T -> LMS: Request reschedule(lessonId, proposedTimes[])
activate LMS
LMS -> S: Request availability(proposedTimes)
activate S
S --> LMS: Availability(choice or ranges)
deactivate S

alt consensus found
  LMS -> T: Confirm new time(chosenTime)
  LMS -> S: Notify confirmed(chosenTime)
else no consensus
  LMS -> T: Notify conflict/need manual handling
  LMS -> S: Notify proposed times expired
end

LMS --> T: Update lesson schedule(lessonId, newTime)
deactivate LMS

@enduml
