@startuml
' --- Scaling and Layout ---
left to right direction
skinparam packageStyle rectangle
skinparam shadowing false
skinparam actorStyle awesome

' --- Primary Actors ---
actor Student as S
actor Teacher as T

rectangle "E-Learning System" {

    ' Payment and Subscription
    usecase "Subscribe to Courses" as UC_Sub
    usecase "Choose Slot" as UC_Slot
    usecase "Make Payments" as UC_Pay
    usecase "Process Transaction" as UC_Proc
    usecase "Apply Discount" as UC_Disc
    
    ' Lessons and Problems
    usecase "Attend Lessons" as UC_Attend
    usecase "Report Problem" as UC_Prob
    usecase "Conduct Lesson" as UC_Conduct
    usecase "Upload Recording" as UC_Rec
    
    ' Authentication
    usecase "Login" as UC_Log
    usecase "Authenticate User" as UC_Auth
    usecase "Reset Password" as UC_Reset
    usecase "Create Account" as UC_Create
    usecase "Verify Email" as UC_Verify
    usecase "Approval" as UC_Approve
    
    ' Scheduling
    usecase "Reschedule Lesson" as UC_Resched
    usecase "Check Availability" as UC_Check
    usecase "Send Notification" as UC_Note
    usecase "Set Schedule" as UC_SetSch
    usecase "Update Schedule" as UC_UpdtSch
    usecase "Confirm Schedule" as UC_ConfSch
    
    ' Files
    usecase "Upload PDFs & Videos" as UC_Upload
    usecase "Validate File" as UC_Valid
    usecase "Replace/Delete File" as UC_Rep
}

' --- Secondary Actors ---
actor Bank as B
actor Admin as A

' --- Connections ---

' Student
S -- UC_Sub
S -- UC_Attend
S -- UC_Resched
S -- UC_Log
S -- UC_Create

' Teacher
T -- UC_Resched
T -- UC_Log
T -- UC_Create
T -- UC_Conduct
T -- UC_Upload
T -- UC_SetSch

' Logic Relationships
UC_Sub ..> UC_Pay : <<include>>
UC_Sub ..> UC_Slot : <<include>>
UC_Pay ..> UC_Proc : <<include>>
UC_Pay <.. UC_Disc : <<extend>>
UC_Proc -- B

UC_Attend <.. UC_Prob : <<extend>>

UC_Resched ..> UC_Check : <<include>>
UC_Check ..> UC_Note : <<include>>

UC_Log ..> UC_Auth : <<include>>
UC_Log <.. UC_Reset : <<extend>>

UC_Create ..> UC_Verify : <<include>>
UC_Create <.. UC_Approve : <<extend>>
UC_Approve -- A

UC_Conduct <.. UC_Rec : <<extend>>

UC_Upload ..> UC_Valid : <<include>>
UC_Upload <.. UC_Rep : <<extend>>

UC_SetSch ..> UC_ConfSch : <<include>>
UC_SetSch <.. UC_UpdtSch : <<extend>>
UC_UpdtSch ..> UC_ConfSch : <<include>>

@enduml

